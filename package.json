{
  "name": "webpocket",
  "version": "0.1.0",
  "description": "Save web pages for offline reading.",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "check": "node --check src/app.js && node --check src/lib/capture.js && node --check src/lib/htmlOptimizer.js && node --check src/lib/storage.js"
  },
  "keywords": [
    "offline",
    "reader",
    "express",
    "ejs"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cheerio": "^1.0.0",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {}
}
