<%- include("partials/head", { title }) %>

<section class="workspace">
  <div class="intro">
    <p class="eyebrow">Offline reader for low-data days</p>
    <h1>Save a lighter copy of any readable page.</h1>
    <p>Paste a URL, import a page you already have, then read it from this device without needing the internet.</p>
  </div>

  <% if (error) { %>
    <div class="alert alert-error" role="alert"><%= error %></div>
  <% } %>
  <% if (notice) { %>
    <div class="alert" role="status"><%= notice %></div>
  <% } %>

  <section class="panel" aria-labelledby="capture-title">
    <div class="panel-heading">
      <h2 id="capture-title">Save from URL</h2>
      <span class="pill">Low data</span>
    </div>
    <form class="stack" action="/capture" method="post">
      <label class="field">
        <span>Web page URL</span>
        <input type="url" name="url" placeholder="https://example.com/article" required inputmode="url" autocomplete="url">
      </label>
      <div class="action-grid" role="group" aria-label="Save or download">
        <button class="primary" type="submit" name="action" value="save-optimized">Save optimized</button>
        <button type="submit" name="action" value="save-with-assets">Save with assets</button>
        <button type="submit" name="action" value="download-html">HTML file</button>
        <button type="submit" name="action" value="download-zip">ZIP + assets</button>
      </div>
    </form>
  </section>

  <section class="panel" aria-labelledby="upload-title">
    <div class="panel-heading">
      <h2 id="upload-title">Open offline files</h2>
      <span class="pill alt">Import</span>
    </div>
    <form class="stack" action="/upload" method="post" enctype="multipart/form-data">
      <label class="file-drop">
        <input type="file" name="offlineFiles" accept=".html,.htm,.zip,text/html,application/zip" multiple>
        <span class="file-title">Choose HTML or ZIP</span>
        <span class="file-subtitle" data-file-label>Works with a single HTML file, optimized HTML, or ZIP with assets.</span>
      </label>
      <label class="file-drop compact-drop">
        <input type="file" name="offlineFiles" multiple webkitdirectory directory>
        <span class="file-title">Choose assets folder</span>
        <span class="file-subtitle" data-file-label>Use this when your HTML file and assets are already in one folder.</span>
      </label>
      <button class="primary" type="submit">Import and read</button>
    </form>
  </section>

  <% if (pages.length) { %>
    <section class="recent" aria-labelledby="recent-title">
      <div class="section-heading">
        <h2 id="recent-title">Recent saves</h2>
        <a href="/library">View all</a>
      </div>
      <div class="page-list compact">
        <% pages.forEach((page) => { %>
          <article class="page-card">
            <a href="/reader/<%= page.id %>">
              <strong><%= page.title %></strong>
              <span><%= page.kind %> · <%= new Date(page.createdAt).toLocaleString() %></span>
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</section>

<%- include("partials/footer") %>
