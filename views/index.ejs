<%- include("partials/head", { title }) %>

<section class="workspace">
  <div class="intro">
    <p class="eyebrow">Offline reader for saved pages</p>
    <h1>Save a web page for offline reading.</h1>
    <p>Paste a URL, keep the page as a full single HTML file, or choose an optimized low-data copy when size matters most.</p>
  </div>

  <% if (error) { %>
    <div class="alert alert-error" role="alert"><%= error %></div>
  <% } %>
  <% if (notice) { %>
    <div class="alert" role="status"><%= notice %></div>
  <% } %>

  <section class="panel" aria-labelledby="capture-title">
    <div class="panel-heading">
      <h2 id="capture-title">Save from URL</h2>
      <span class="pill">Full page first</span>
    </div>
    <form class="stack" action="/capture" method="post">
      <label class="field">
        <span>Web page URL</span>
        <input type="url" name="url" placeholder="https://example.com/article" required inputmode="url" autocomplete="url">
      </label>
      <details class="auth-options">
        <summary>Authenticated page options</summary>
        <p class="field-help">Use these for pages that require login. Values are only applied to this capture request; token-like storage keys are auto-used as bearer tokens, and {{localStorage.key}} or {{sessionStorage.key}} templates work in custom headers. By default auth is sent to the page host and same-origin assets only.</p>
        <div class="auth-grid">
          <label class="field">
            <span>Bearer token</span>
            <input type="password" name="bearerToken" placeholder="eyJ..." autocomplete="off" spellcheck="false">
          </label>
          <label class="field">
            <span>Cookie header</span>
            <input type="password" name="cookies" placeholder="session=...; csrf=..." autocomplete="off" spellcheck="false">
          </label>
        </div>
        <div class="storage-pair" aria-label="Local storage key and value">
          <label class="field">
            <span>Local storage key</span>
            <input type="text" name="localStorageKey" placeholder="accessToken" autocomplete="off" spellcheck="false">
          </label>
          <label class="field">
            <span>Local storage value</span>
            <input type="password" name="localStorageValue" placeholder="token or JSON value" autocomplete="off" spellcheck="false">
          </label>
        </div>
        <div class="storage-pair" aria-label="Session storage key and value">
          <label class="field">
            <span>Session storage key</span>
            <input type="text" name="sessionStorageKey" placeholder="sessionToken" autocomplete="off" spellcheck="false">
          </label>
          <label class="field">
            <span>Session storage value</span>
            <input type="password" name="sessionStorageValue" placeholder="token or JSON value" autocomplete="off" spellcheck="false">
          </label>
        </div>
        <label class="field">
          <span>Request headers JSON</span>
          <textarea name="headersJson" rows="4" placeholder='{ "authorization": "Bearer {{localStorage.accessToken}}", "x-api-key": "..." }' spellcheck="false"></textarea>
        </label>
        <label class="checkbox-field">
          <input type="checkbox" name="sendAuthToAllHosts">
          <span>Send auth headers to cross-origin assets too (only enable for trusted domains).</span>
        </label>
      </details>
      <div class="action-grid" role="group" aria-label="Save or download">
        <button class="primary" type="submit" name="action" value="save-single">Save single page</button>
        <button type="submit" name="action" value="download-html">Single HTML</button>
        <button type="submit" name="action" value="download-zip">ZIP + assets</button>
        <button type="submit" name="action" value="save-with-assets">Save assets</button>
        <button type="submit" name="action" value="save-optimized">Optimize save</button>
        <button type="submit" name="action" value="download-optimized">Optimize HTML</button>
      </div>
    </form>
  </section>

  <section class="panel" aria-labelledby="upload-title">
    <div class="panel-heading">
      <h2 id="upload-title">Open offline files</h2>
      <span class="pill alt">Import</span>
    </div>
    <form class="stack" action="/upload" method="post" enctype="multipart/form-data">
      <label class="file-drop">
        <input type="file" name="offlineFiles" accept=".html,.htm,.zip,text/html,application/zip" multiple>
        <span class="file-title">Choose HTML or ZIP</span>
        <span class="file-subtitle" data-file-label>Works with a single HTML file, optimized HTML, or ZIP with assets.</span>
      </label>
      <label class="file-drop compact-drop">
        <input type="file" name="offlineFiles" multiple webkitdirectory directory>
        <span class="file-title">Choose assets folder</span>
        <span class="file-subtitle" data-file-label>Use this when your HTML file and assets are already in one folder.</span>
      </label>
      <div class="action-grid">
        <button class="primary" type="submit" name="uploadMode" value="preserve-assets">Import with assets</button>
        <button type="submit" name="uploadMode" value="single-html">Convert to single HTML</button>
      </div>
    </form>
  </section>

  <% if (pages.length) { %>
    <section class="recent" aria-labelledby="recent-title">
      <div class="section-heading">
        <h2 id="recent-title">Recent saves</h2>
        <a href="/library">View all</a>
      </div>
      <div class="page-list compact">
        <% pages.forEach((page) => { %>
          <article class="page-card">
            <a class="page-card-main" href="/reader/<%= page.id %>">
              <strong><%= page.title %></strong>
              <span><%= page.kind %> - <%= formatBytes(page.sizeBytes) %> - <%= new Date(page.createdAt).toLocaleString() %></span>
            </a>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</section>

<%- include("partials/footer") %>
