    </main>
    <div class="processing-overlay" data-processing-overlay hidden>
      <div class="processing-card" role="status" aria-live="polite" aria-atomic="true">
        <span class="processing-spinner" aria-hidden="true"></span>
        <div>
          <strong data-processing-title>Processing page</strong>
          <p data-processing-message>This can take a moment while webpocket fetches and prepares offline files.</p>
        </div>
      </div>
    </div>
    <div class="confirm-overlay" data-confirm-overlay hidden>
      <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="confirm-title" aria-describedby="confirm-message">
        <div class="confirm-icon" aria-hidden="true">!</div>
        <div class="confirm-copy">
          <strong id="confirm-title">Remove saved page?</strong>
          <p id="confirm-message" data-confirm-message>This will delete the saved files from local storage.</p>
        </div>
        <div class="confirm-actions">
          <button class="confirm-cancel" type="button" data-confirm-cancel>Cancel</button>
          <button class="confirm-remove" type="button" data-confirm-remove>Remove</button>
        </div>
      </div>
    </div>
    <script src="/js/app.js?v=9" defer></script>
  </body>
</html>
